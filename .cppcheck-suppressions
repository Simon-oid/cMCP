# cMCP cppcheck suppressions (Tier 6 axis 6.2.2)
#
# Format: <id>:<file>:<line>  — or just <id> for a global suppression.
# Triaged 2026-05-26. Each entry pinned with a rationale.

# unusedFunction: public-API symbols in include/cmcp_*.h are
#   intentionally exported for consumers; cppcheck has no view of the
#   downstream consumer, so flags them. We rely on header-presence
#   audits (and downstream link errors) instead.
unusedFunction

# missingInclude / missingIncludeSystem: noisy when cppcheck can't see
#   libcurl / pthread headers in its sandbox. The compiler is the
#   authority on this — if it builds, the include graph is fine.
missingInclude
missingIncludeSystem

# unmatchedSuppression: cppcheck warns if a per-file suppression below
#   no longer matches. Useful long-term, but during the initial triage
#   we want the build to keep passing while we iterate; flip on once
#   the suppression list is settled.
unmatchedSuppression
