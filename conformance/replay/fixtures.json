      "server": "tools/crag-mcp/crag-mcp",
      "args": ["--db", "/tmp/cmcp-replay-crag-empty.db"],
      "setup": ["rm -f /tmp/cmcp-replay-crag-empty.db"],
      "teardown": ["rm -f /tmp/cmcp-replay-crag-empty.db"],
