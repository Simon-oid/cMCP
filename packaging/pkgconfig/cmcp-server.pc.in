prefix=@PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: cmcp-server
Description: cMCP server library (tool/resource/prompt registry, dispatch, worker pool)
URL: https://github.com/Simon-oid/cMCP
Version: @VERSION@
Requires: cmcp-core
Libs: -L${libdir} -lcmcp_server
Cflags: -I${includedir}
