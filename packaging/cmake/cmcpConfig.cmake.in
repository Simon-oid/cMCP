# cmcpConfig.cmake — find_package(cmcp) entry point.
#
# Generated by cMCP's `make install` (sed-substituted from
# packaging/cmake/cmcpConfig.cmake.in). The substitution baked
# @PREFIX@ and @VERSION@ at install time; everything else is
# resolved at find_package() time on the consumer's machine.
#
# Components: core, server, client. The library is static-by-default
# (per cMCP's posture); the imported targets reflect that. If the
# library was installed with ENABLE_SHARED=1 *and* the static .a is
# absent, the imported targets fall back to the .so.

set(CMCP_VERSION "@VERSION@")

set(_cmcp_prefix     "@PREFIX@")
set(_cmcp_libdir     "${_cmcp_prefix}/lib")
set(_cmcp_includedir "${_cmcp_prefix}/include")

include(CMakeFindDependencyMacro)
find_dependency(Threads)
find_dependency(CURL)

set(_cmcp_components core server client)

foreach(_comp ${_cmcp_components})
    set(_static "${_cmcp_libdir}/libcmcp_${_comp}.a")
    set(_shared "${_cmcp_libdir}/libcmcp_${_comp}.so")
    if(EXISTS "${_static}")
        if(NOT TARGET cmcp::${_comp})
            add_library(cmcp::${_comp} STATIC IMPORTED)
            set_target_properties(cmcp::${_comp} PROPERTIES
                IMPORTED_LOCATION "${_static}"
                INTERFACE_INCLUDE_DIRECTORIES "${_cmcp_includedir}")
        endif()
    elseif(EXISTS "${_shared}")
        if(NOT TARGET cmcp::${_comp})
            add_library(cmcp::${_comp} SHARED IMPORTED)
            set_target_properties(cmcp::${_comp} PROPERTIES
                IMPORTED_LOCATION "${_shared}"
                INTERFACE_INCLUDE_DIRECTORIES "${_cmcp_includedir}")
        endif()
    endif()
endforeach()

# Dependency wiring. server/client both pull in core; core pulls in
# libcurl + pthread (the transport's hard deps). Static linking
# requires this chain to be expressed so the consumer's link line
# picks up the transitive symbols.
if(TARGET cmcp::core)
    set_target_properties(cmcp::core PROPERTIES
        INTERFACE_LINK_LIBRARIES "CURL::libcurl;Threads::Threads")
endif()
if(TARGET cmcp::server AND TARGET cmcp::core)
    set_target_properties(cmcp::server PROPERTIES
        INTERFACE_LINK_LIBRARIES "cmcp::core")
endif()
if(TARGET cmcp::client AND TARGET cmcp::core)
    set_target_properties(cmcp::client PROPERTIES
        INTERFACE_LINK_LIBRARIES "cmcp::core")
endif()

# Component validation. If the consumer's find_package(...) listed
# components, every required one must resolve to an imported target.
if(cmcp_FIND_COMPONENTS)
    foreach(_comp ${cmcp_FIND_COMPONENTS})
        if(NOT TARGET cmcp::${_comp})
            if(cmcp_FIND_REQUIRED_${_comp})
                set(cmcp_FOUND False)
                set(cmcp_NOT_FOUND_MESSAGE
                    "cmcp: required component '${_comp}' is not installed at ${_cmcp_libdir}")
                return()
            endif()
        else()
            set(cmcp_${_comp}_FOUND True)
        endif()
    endforeach()
endif()

set(cmcp_FOUND True)
