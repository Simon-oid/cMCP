*.o
*.a
*.so
*.so.*
build/
.cache/

# Source tarballs produced by `make dist` (Tier 6 axis 6.4)
cmcp-*.tar.gz

# Doxygen output (Tier 6 axis 6.3). `make docs` regenerates everything
# under docs/api/; we don't track the generated reference site.
docs/api/

# install-smoke consumer build artefacts (compiled in temp dirs, but
# the local Makefile drops pkgconfig-smoke here when invoked by hand).
examples/install-smoke/pkgconfig-smoke
examples/install-smoke/cmake-smoke
examples/install-smoke/build/

# Reference binaries
tools/crag-mcp/crag-mcp
tools/cmcp-inspect/cmcp-inspect
tools/filesystem-mcp/filesystem-mcp
tools/cmcp-tee/cmcp-tee

# Example binaries
examples/echo-server
examples/minimal-client

# Compiled test binaries (source is tests/test_*.c, binaries are tests/test_<name>)
tests/test_*
!tests/test_*.c
!tests/test.h

# Conformance harness: the built C driver + npm-installed reference SDKs.
# package.json / *.mjs ARE tracked; node_modules and the binary are not.
conformance/client_vs_ts
conformance/node_modules/
conformance/package-lock.json

# Fuzz harnesses: the *.c sources and the hand-written seed_* corpus
# entries ARE tracked. Binaries, crash artifacts, and the random
# coverage-driven entries libFuzzer appends to corpus_* during a run
# are not — only the curated seeds belong in git.
fuzz/fuzz_json
fuzz/fuzz_rpc
fuzz/fuzz_schema
fuzz/fuzz_http
fuzz/artifacts_*/
fuzz/crash-*
fuzz/timeout-*
fuzz/leak-*
fuzz/corpus_*/*
!fuzz/corpus_*/seed_*

# Soak harness: the *.c driver and run.sh ARE tracked; the compiled
# binary and any CSV captures are not.
tests/soak/soak_driver
tests/soak/*.csv

# Bench tree (Tier 6 axis 6.6.1): sources, README, run.sh ARE tracked;
# compiled binaries and the per-run results.csv are not (numbers vary
# by machine, kernel, and build flags).
bench/bench_server_inline
bench/bench_server_pool
bench/bench_http
bench/results.csv

# Coverage artifacts (Tier 6 axis 6.2.1). The Makefile target regenerates
# everything under coverage/ on demand; gcov drops .gcno alongside the
# .o it instrumented and .gcda alongside the binary that ran it.
*.gcno
*.gcda
*.gcov
coverage/

# Editor / tool state
.claude/

# Project-scope MCP server config — contains absolute paths, local
# to each developer's machine. Not part of the public deliverable.
.mcp.json

# Personal working notes — kept locally, never pushed.
# CLAUDE.md is the AI-coding playbook for this repo; TODO.md is the
# evolving roadmap. Both are useful while developing but not part of
# the public deliverable, so they live in the working tree only.
CLAUDE.md
TODO.md
todo.md
notes.md
