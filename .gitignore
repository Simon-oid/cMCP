conformance/node_modules/
conformance/package-lock.json

# Editor / tool state
.claude/

# Project-scope MCP server config — contains absolute paths, local
# to each developer's machine. Not part of the public deliverable.
.mcp.json

# Personal working notes — kept locally, never pushed.
